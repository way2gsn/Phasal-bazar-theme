{% unless skip_styles %}
  {{ 'phasal-product-card.css' | asset_url | stylesheet_tag }}
{% endunless %}

{%- if card_product and card_product != empty -%}
  {%- liquid
    assign variant = card_product.selected_or_first_available_variant
    assign badge_class = 'phasal-product-card__badge--network'
    assign badge_text = default_badge | default: '72K+ network'
    if card_product.available == false
      assign badge_class = 'phasal-product-card__badge--sold'
      assign badge_text = 'Sold out'
    elsif card_product.compare_at_price_max > card_product.price
      assign badge_class = 'phasal-product-card__badge--sale'
      assign badge_text = 'Best seller'
    elsif card_product.tags contains 'organic'
      assign badge_class = 'phasal-product-card__badge--organic'
      assign badge_text = 'Organic'
    endif
  -%}

  <article
    class="phasal-product-card"
    data-phasal-product-card
    data-variant-id="{{ variant.id }}"
    data-product-title="{{ card_product.title | escape }}"
  >
    <div class="phasal-product-card__media">
      <span class="phasal-product-card__badge {{ badge_class }}">{{ badge_text }}</span>
      <a href="{{ card_product.url }}">
        {%- if card_product.featured_image != blank -%}
          {{
            card_product.featured_image
            | image_url: width: 900
            | image_tag:
              widths: '360, 540, 720, 900',
              sizes: '(max-width: 749px) 100vw, (max-width: 989px) 50vw, 25vw',
              loading: 'lazy',
              alt: card_product.title
          }}
        {%- endif -%}
      </a>
    </div>
    <div class="phasal-product-card__body">
      <div class="phasal-product-card__tags">
        {%- if card_product.type != blank -%}
          <span class="phasal-product-card__tag">{{ card_product.type | escape }}</span>
        {%- endif -%}
        {%- assign first_tag = card_product.tags | first -%}
        {%- if first_tag != blank -%}
          <span class="phasal-product-card__tag">{{ first_tag | escape }}</span>
        {%- endif -%}
      </div>
      <h3 class="phasal-product-card__title"><a href="{{ card_product.url }}">{{ card_product.title | escape }}</a></h3>
      <div class="phasal-product-card__description">
        {%- if card_product.metafields.custom.short_description != blank -%}
          {{ card_product.metafields.custom.short_description | metafield_tag | strip_html }}
        {%- else -%}
          {{ card_product.description | strip_html | truncate: 95 }}
        {%- endif -%}
      </div>
      <div class="phasal-product-card__features">
        {%- if card_product.available -%}
          <span class="phasal-product-card__feature">Available now</span>
        {%- endif -%}
        {%- if card_product.compare_at_price_max > card_product.price -%}
          <span class="phasal-product-card__feature">On sale</span>
        {%- endif -%}
      </div>
      {%- if card_product.metafields.reviews.rating.value != blank -%}
        <div class="phasal-product-card__rating">
          ★ {{ card_product.metafields.reviews.rating.value.rating }} ({{ card_product.metafields.reviews.rating_count }})
        </div>
      {%- endif -%}
      <div class="phasal-product-card__footer">
        <div class="phasal-product-card__price-wrap">
          {%- if variant.compare_at_price > variant.price -%}
            <span class="phasal-product-card__compare">{{ variant.compare_at_price | money }}</span>
          {%- endif -%}
          <span class="phasal-product-card__price">{{ variant.price | money }}</span>
          {%- if variant.unit_price_measurement != blank -%}
            <span class="phasal-product-card__unit">
              per {{ variant.unit_price_measurement.reference_value }}{{ variant.unit_price_measurement.reference_unit }}
            </span>
          {%- endif -%}
        </div>
        {%- if card_product.available == false -%}
          <a class="phasal-product-card__options-link" href="{{ card_product.url }}" aria-label="View {{ card_product.title | escape }}">→</a>
        {%- else -%}
          <div class="phasal-product-card__form">
            <div class="phasal-product-card__actions">
              <button
                class="phasal-product-card__cart-button"
                type="button"
                data-phasal-add
                aria-label="Add {{ card_product.title | escape }} to cart"
              >
                <span>Add to Cart</span>
              </button>
              <button
                class="phasal-product-card__buy-button"
                type="button"
                data-phasal-buy-now
                aria-label="Buy {{ card_product.title | escape }} now"
              >
                <span>Buy Now</span>
              </button>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </article>
{%- endif -%}
