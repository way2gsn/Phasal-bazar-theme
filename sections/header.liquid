{{ 'phasal-shell.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign sticky_class = ''
  if section.settings.sticky_header_type != 'none'
    assign sticky_class = ' phasal-header--sticky'
  endif

  assign use_reference_top_nav = false
  if section.settings.menu.links.size == 0
    assign use_reference_top_nav = true
  elsif section.settings.menu.links.size <= 3
    assign first_top_title = section.settings.menu.links.first.title | downcase
    if first_top_title == 'home'
      assign use_reference_top_nav = true
    endif
  endif

  assign top_nav_blocks = section.blocks | where: 'type', 'top_link'
  if top_nav_blocks.size > 0
    assign use_reference_top_nav = false
  endif

  assign use_reference_category_tabs = false
  if section.settings.category_menu.links.size == 0
    assign use_reference_category_tabs = true
  elsif section.settings.category_menu.links.size <= 3
    assign first_category_title = section.settings.category_menu.links.first.title | downcase
    if first_category_title == 'home'
      assign use_reference_category_tabs = true
    endif
  endif
-%}

<section class="phasal-shell phasal-header{{ sticky_class }}">
  <div class="phasal-shell__inner phasal-header__main">
    <details class="phasal-header__mobile-nav">
      <summary class="phasal-header__mobile-toggle" aria-label="Open menu">
        <span class="phasal-header__icon">{{ 'icon-hamburger.svg' | inline_asset_content }}</span>
      </summary>
      <div class="phasal-header__mobile-panel">
        <nav class="phasal-header__mobile-menu" aria-label="Mobile primary">
          {%- if top_nav_blocks.size > 0 -%}
            {%- for block in top_nav_blocks -%}
              {%- if block.settings.label != blank -%}
                <a class="phasal-header__mobile-link" href="{{ block.settings.link | default: routes.root_url }}" {{ block.shopify_attributes }}>
                  {{ block.settings.label | escape }}
                </a>
              {%- endif -%}
            {%- endfor -%}
          {%- elsif use_reference_top_nav -%}
            <a class="phasal-header__mobile-link" href="#shop-by-grain">Shop by Grain</a>
            <a class="phasal-header__mobile-link" href="#shop-by-form">Shop by Form</a>
            <a class="phasal-header__mobile-link" href="#farm-to-table-story">Farm to Table Story</a>
            <a class="phasal-header__mobile-link" href="#impact">Impact</a>
            <a class="phasal-header__mobile-link" href="/pages/about-us">About Us</a>
            <a class="phasal-header__mobile-link" href="{{ routes.blog_url }}">Blog</a>
          {%- else -%}
            {%- for link in section.settings.menu.links -%}
              <a class="phasal-header__mobile-link" href="{{ link.url }}">{{ link.title | escape }}</a>
            {%- endfor -%}
          {%- endif -%}
        </nav>
        <div class="phasal-header__mobile-categories">
          {%- if use_reference_category_tabs -%}
            <a class="phasal-header__mobile-link" href="{{ routes.all_products_collection_url }}">All Products</a>
            <a class="phasal-header__mobile-link" href="{{ routes.collections_url | append: '/kodo-millet' }}">Kodo Millet</a>
            <a class="phasal-header__mobile-link" href="{{ routes.collections_url | append: '/foxtail-millet' }}">Foxtail Millet</a>
            <a class="phasal-header__mobile-link" href="{{ routes.collections_url | append: '/little-millet' }}">Little Millet</a>
            <a class="phasal-header__mobile-link" href="{{ routes.collections_url | append: '/barnyard-millet' }}">Barnyard Millet</a>
            <a class="phasal-header__mobile-link" href="{{ routes.collections_url | append: '/finger-millet' }}">Finger Millet</a>
            <a class="phasal-header__mobile-link" href="{{ routes.collections_url | append: '/cold-press-oils' }}">Cold-Press Oils</a>
            <a class="phasal-header__mobile-link" href="{{ routes.collections_url | append: '/poha-aata' }}">Poha &amp; Aata</a>
            <a class="phasal-header__mobile-link" href="{{ routes.collections_url | append: '/combo-packs' }}">Combo Packs</a>
            <a class="phasal-header__mobile-link" href="{{ routes.blog_url }}">Recipes</a>
          {%- else -%}
            {%- for link in section.settings.category_menu.links -%}
              <a class="phasal-header__mobile-link" href="{{ link.url }}">{{ link.title | escape }}</a>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    </details>

    <a class="phasal-header__logo" href="{{ routes.root_url }}">
      {%- if settings.logo != blank -%}
        {{
          settings.logo
          | image_url: width: 600
          | image_tag:
            widths: '120, 180, 240, 320, 420, 600',
            sizes: '(max-width: 749px) 120px, 160px',
            alt: settings.logo.alt | default: shop.name,
            preload: true
        }}
      {%- else -%}
        <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" width="1024" height="1024">
      {%- endif -%}
    </a>

    {%- if section.settings.show_search -%}
      <div class="phasal-header__search">
        <form action="{{ routes.search_url }}" method="get" role="search">
          <div class="phasal-header__search-inner">
            <span class="phasal-header__search-icon">{{ 'icon-search.svg' | inline_asset_content }}</span>
            <input
              type="search"
              name="q"
              value="{{ search.terms | escape }}"
              placeholder="{{ section.settings.search_placeholder | escape }}"
            >
            <input type="hidden" name="options[prefix]" value="last">
          </div>
        </form>
      </div>
    {%- endif -%}

    <nav class="phasal-header__top-nav" aria-label="Primary">
      {%- if top_nav_blocks.size > 0 -%}
        {%- for block in top_nav_blocks -%}
          {%- if block.settings.label != blank -%}
            <a
              class="phasal-header__top-link{% if block.settings.highlight %} phasal-header__top-link--highlight{% endif %}"
              href="{{ block.settings.link | default: routes.root_url }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.label | escape }}
              {%- if block.settings.show_caret -%}
                <span>{{ 'icon-caret.svg' | inline_asset_content }}</span>
              {%- endif -%}
            </a>
          {%- endif -%}
        {%- endfor -%}
      {%- elsif use_reference_top_nav -%}
        <a class="phasal-header__top-link" href="#shop-by-grain">
          Shop by Grain
          <span>{{ 'icon-caret.svg' | inline_asset_content }}</span>
        </a>
        <a class="phasal-header__top-link" href="#shop-by-form">
          Shop by Form
          <span>{{ 'icon-caret.svg' | inline_asset_content }}</span>
        </a>
        <a class="phasal-header__top-link" href="#farm-to-table-story">
          Farm to Table Story
          <span>{{ 'icon-caret.svg' | inline_asset_content }}</span>
        </a>
        <a class="phasal-header__top-link" href="#impact">Impact</a>
        <a class="phasal-header__top-link" href="{{ routes.blog_url }}">Blog</a>
        <a class="phasal-header__top-link phasal-header__top-link--highlight" href="/pages/about-us">About Us</a>
      {%- else -%}
        {%- for link in section.settings.menu.links -%}
          <a class="phasal-header__top-link" href="{{ link.url }}">
            {{ link.title | escape }}
            {%- if link.links != blank -%}
              <span>{{ 'icon-caret.svg' | inline_asset_content }}</span>
            {%- endif -%}
          </a>
        {%- endfor -%}
      {%- endif -%}
    </nav>

    <div class="phasal-header__actions">
      {%- if shop.customer_accounts_enabled -%}
        <div class="phasal-header__account">
          <a class="phasal-header__icon-button" href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" aria-label="Account">
            <span class="phasal-header__icon">{{ 'icon-account.svg' | inline_asset_content }}</span>
          </a>
          <div class="phasal-header__account-dropdown">
            {%- if customer -%}
              <a href="{{ routes.account_url }}">My Account</a>
              <a href="{{ routes.account_url }}">Order History</a>
              <a href="{{ routes.account_logout_url }}">Logout</a>
            {%- else -%}
              <a href="{{ routes.account_login_url }}">Login</a>
              <a href="{{ routes.account_register_url }}">Create Account</a>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
      <button class="phasal-header__icon-button phasal-header__icon-button--wishlist" type="button" aria-label="Wishlist" data-phasal-wishlist-open>
        <span class="phasal-header__icon">{{ 'icon-heart.svg' | inline_asset_content }}</span>
        <span class="phasal-header__wishlist-count" data-phasal-wishlist-count hidden>0</span>
      </button>
      <a class="phasal-header__cart" href="{{ routes.cart_url }}" id="cart-icon-bubble">
        <span class="phasal-header__cart-icon">{{ 'icon-cart.svg' | inline_asset_content }}</span>
        <span>Cart</span>
        <span class="phasal-header__cart-count" data-phasal-cart-count>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>

  <div class="phasal-header__categories">
    <nav class="phasal-shell__inner phasal-header__categories-inner" aria-label="Collections">
      {%- if use_reference_category_tabs -%}
        <a class="phasal-header__category-link phasal-header__category-link--active" href="{{ routes.all_products_collection_url }}"><span class="phasal-header__category-icon" aria-hidden="true">🌾</span>All Products</a>
        <a class="phasal-header__category-link" href="{{ routes.collections_url | append: '/kodo-millet' }}"><span class="phasal-header__category-icon" aria-hidden="true">🌿</span>Kodo Millet</a>
        <a class="phasal-header__category-link" href="{{ routes.collections_url | append: '/foxtail-millet' }}"><span class="phasal-header__category-icon" aria-hidden="true">🟡</span>Foxtail Millet</a>
        <a class="phasal-header__category-link" href="{{ routes.collections_url | append: '/little-millet' }}"><span class="phasal-header__category-icon" aria-hidden="true">⚪</span>Little Millet</a>
        <a class="phasal-header__category-link" href="{{ routes.collections_url | append: '/barnyard-millet' }}"><span class="phasal-header__category-icon" aria-hidden="true">🟤</span>Barnyard Millet</a>
        <a class="phasal-header__category-link" href="{{ routes.collections_url | append: '/finger-millet' }}"><span class="phasal-header__category-icon" aria-hidden="true">🟠</span>Finger Millet</a>
        <a class="phasal-header__category-link" href="{{ routes.collections_url | append: '/cold-press-oils' }}"><span class="phasal-header__category-icon" aria-hidden="true">🫙</span>Cold-Press Oils</a>
        <a class="phasal-header__category-link" href="{{ routes.collections_url | append: '/poha-aata' }}"><span class="phasal-header__category-icon" aria-hidden="true">🥣</span>Poha &amp; Aata</a>
        <a class="phasal-header__category-link" href="{{ routes.collections_url | append: '/combo-packs' }}"><span class="phasal-header__category-icon" aria-hidden="true">🎁</span>Combo Packs</a>
        <a class="phasal-header__category-link" href="{{ routes.blog_url }}"><span class="phasal-header__category-icon" aria-hidden="true">📖</span>Recipes</a>
      {%- else -%}
        {%- for link in section.settings.category_menu.links -%}
          <a class="phasal-header__category-link{% if link.current %} phasal-header__category-link--active{% endif %}" href="{{ link.url }}">
            <span class="phasal-header__category-icon" aria-hidden="true">
              {%- liquid
                assign category_title = link.title | downcase
                case category_title
                  when 'all products'
                    echo '🌾'
                  when 'kodo millet'
                    echo '🌿'
                  when 'foxtail millet'
                    echo '🟡'
                  when 'little millet'
                    echo '⚪'
                  when 'barnyard millet'
                    echo '🟤'
                  when 'finger millet'
                    echo '🟠'
                  when 'cold-press oils', 'cold-pressed oils'
                    echo '🫙'
                  when 'poha & aata', 'poha and aata'
                    echo '🥣'
                  when 'combo packs'
                    echo '🎁'
                  when 'recipes'
                    echo '📖'
                  else
                    echo '•'
                endcase
              -%}
            </span>
            {{ link.title | escape }}
          </a>
        {%- endfor -%}
      {%- endif -%}
    </nav>
  </div>

  <div class="phasal-wishlist" data-phasal-wishlist-panel>
    <div class="phasal-wishlist__sheet">
      <div class="phasal-wishlist__header">
        <h2>Wishlist</h2>
        <button type="button" data-phasal-wishlist-close aria-label="Close wishlist">×</button>
      </div>
      <p class="phasal-wishlist__empty" data-phasal-wishlist-empty>Your saved products will appear here.</p>
      <div class="phasal-wishlist__list" data-phasal-wishlist-list></div>
    </div>
  </div>
</section>

{%- if section.settings.sticky_header_type != 'none' -%}
  <script>
    (() => {
      const headerSection = document.getElementById('shopify-section-{{ section.id }}');
      if (!headerSection) return;

      const stickyContainer =
        headerSection.closest('.shopify-section-group-header-group') || headerSection.closest('.shopify-section');

      if (stickyContainer) {
        stickyContainer.classList.add('phasal-sticky-shell');
      }
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Top navigation menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "category_menu",
      "label": "Category menu"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search",
      "default": true
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search millets, oils, poha, aata..."
    },
    {
      "type": "select",
      "id": "sticky_header_type",
      "label": "Sticky header",
      "default": "on-scroll-up",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "on-scroll-up", "label": "Sticky" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "top_link",
      "name": "Top link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Shop by Grain"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "show_caret",
          "label": "Show caret icon",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "highlight",
          "label": "Highlight link",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
