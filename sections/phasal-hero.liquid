{{ 'phasal-home.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign hero_slide_blocks = section.blocks | where: 'type', 'hero_slide'
  assign stat_blocks = section.blocks | where: 'type', 'stat'
  assign feature_blocks = section.blocks | where: 'type', 'feature_card'
-%}

<section
  id="PhasalHero-{{ section.id }}"
  class="phasal-home phasal-hero{% if hero_slide_blocks.size > 1 %} phasal-hero--carousel{% endif %}"
  {% if hero_slide_blocks.size > 1 %}
    data-phasal-hero-carousel
    data-auto-rotate="{{ section.settings.auto_rotate }}"
    data-interval="{{ section.settings.change_slides_speed | times: 1000 }}"
  {% endif %}
>
  <div class="phasal-hero__slides">
    {%- if hero_slide_blocks.size > 0 -%}
      {%- for block in hero_slide_blocks -%}
        {%- liquid
          assign slide_products = blank
          if block.settings.product_collection != blank
            assign slide_products = block.settings.product_collection.products
          endif
        -%}
        <article
          class="phasal-hero__slide{% if forloop.first %} is-active{% endif %}"
          data-phasal-hero-slide
          {{ block.shopify_attributes }}
        >
          <div class="phasal-hero__media">
            {%- if block.settings.background_image != blank -%}
              {{
                block.settings.background_image
                | image_url: width: 2400
                | image_tag:
                  widths: '750, 1100, 1500, 2000, 2400',
                  sizes: '100vw',
                  loading: 'eager'
              }}
            {%- elsif section.settings.background_image != blank -%}
              {{
                section.settings.background_image
                | image_url: width: 2400
                | image_tag:
                  widths: '750, 1100, 1500, 2000, 2400',
                  sizes: '100vw',
                  loading: 'eager'
              }}
            {%- endif -%}
          </div>
          <div class="phasal-hero__overlay"></div>

          <div class="phasal-hero__inner">
            <div class="phasal-hero__content">
              <div class="phasal-hero__badges">
                {%- if block.settings.eyebrow != blank -%}
                  <span class="phasal-hero__badge">
                    <span class="phasal-hero__badge-dot"></span>
                    {{ block.settings.eyebrow | escape }}
                  </span>
                {%- endif -%}
                {%- if block.settings.meta != blank -%}
                  <span class="phasal-hero__meta">{{ block.settings.meta | escape }}</span>
                {%- endif -%}
              </div>

              <h2 class="phasal-hero__title">
                {{ block.settings.heading_line_1 | escape }}<br>
                <span class="phasal-hero__title-accent">{{ block.settings.heading_line_2 | escape }}</span><br>
                <span class="phasal-hero__title-highlight">{{ block.settings.heading_line_3 | escape }}</span>
              </h2>

              {%- if block.settings.subheading != blank -%}
                <p class="phasal-hero__subtitle">{{ block.settings.subheading | escape }}</p>
              {%- endif -%}

              <div class="phasal-hero__actions">
                {%- if block.settings.primary_button_label != blank -%}
                  <a
                    class="phasal-home__button phasal-home__button--primary"
                    href="{{ block.settings.primary_button_link | default: routes.all_products_collection_url }}"
                  >
                    {{ block.settings.primary_button_label | escape }}
                  </a>
                {%- endif -%}
                {%- if block.settings.secondary_button_label != blank -%}
                  <a
                    class="phasal-home__button phasal-home__button--secondary"
                    href="{{ block.settings.secondary_button_link | default: routes.root_url }}"
                  >
                    {{ block.settings.secondary_button_label | escape }}
                  </a>
                {%- endif -%}
              </div>

              {%- if block.settings.stat_1_num != blank or block.settings.stat_2_num != blank or block.settings.stat_3_num != blank or block.settings.stat_4_num != blank -%}
                <div class="phasal-hero__stats">
                  {%- if block.settings.stat_1_num != blank -%}
                    <div>
                      <div class="phasal-hero__stat-number">{{ block.settings.stat_1_num | escape }}</div>
                      <div class="phasal-hero__stat-label">{{ block.settings.stat_1_label | escape }}</div>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.stat_2_num != blank -%}
                    <div>
                      <div class="phasal-hero__stat-number">{{ block.settings.stat_2_num | escape }}</div>
                      <div class="phasal-hero__stat-label">{{ block.settings.stat_2_label | escape }}</div>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.stat_3_num != blank -%}
                    <div>
                      <div class="phasal-hero__stat-number">{{ block.settings.stat_3_num | escape }}</div>
                      <div class="phasal-hero__stat-label">{{ block.settings.stat_3_label | escape }}</div>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.stat_4_num != blank -%}
                    <div>
                      <div class="phasal-hero__stat-number">{{ block.settings.stat_4_num | escape }}</div>
                      <div class="phasal-hero__stat-label">{{ block.settings.stat_4_label | escape }}</div>
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>

            <div class="phasal-hero__cards">
              {%- if block.settings.show_product_cards and block.settings.product_collection != blank and slide_products.size > 0 -%}
                <div class="phasal-hero__card-grid">
                  {%- for product in slide_products limit: 2 -%}
                    {%- assign variant = product.selected_or_first_available_variant -%}
                    <a class="phasal-hero-card phasal-hero-card--linked" href="{{ product.url }}">
                      <div class="phasal-hero-card__image">
                        {%- if product.featured_image != blank -%}
                          {{
                            product.featured_image
                            | image_url: width: 900
                            | image_tag:
                              widths: '360, 540, 720, 900',
                              sizes: '(max-width: 749px) 100vw, 28vw'
                          }}
                        {%- endif -%}
                      </div>
                      <div class="phasal-hero-card__body">
                        <h3 class="phasal-hero-card__title">{{ product.title | escape }}</h3>
                        {%- if product.metafields.custom.short_description != blank -%}
                          <p class="phasal-hero-card__copy">{{ product.metafields.custom.short_description | metafield_tag | strip_html }}</p>
                        {%- elsif product.description != blank -%}
                          <p class="phasal-hero-card__copy">{{ product.description | strip_html | truncate: 70 }}</p>
                        {%- endif -%}
                        {%- if variant != blank -%}
                          <div class="phasal-hero-card__price">
                            {{ variant.price | money }}
                            {%- if variant.unit_price_measurement != blank -%}
                              <span class="phasal-hero-card__price-unit">
                                /
                                {{ variant.unit_price_measurement.reference_value -}}
                                {{- variant.unit_price_measurement.reference_unit }}
                              </span>
                            {%- endif -%}
                          </div>
                        {%- endif -%}
                      </div>
                    </a>
                  {%- endfor -%}
                </div>
              {%- endif -%}

              {%- if block.settings.show_feature_card -%}
                <article class="phasal-hero-card phasal-hero-card--feature">
                  <div class="phasal-hero-card__image">
                    {%- if block.settings.feature_image != blank -%}
                      {{
                        block.settings.feature_image
                        | image_url: width: 1600
                        | image_tag:
                          widths: '540, 900, 1200, 1600',
                          sizes: '(max-width: 749px) 100vw, 38vw'
                      }}
                    {%- else -%}
                      <img src="{{ 'farm_banner.png' | asset_url }}" alt="{{ block.settings.feature_title | escape }}" width="3168" height="1344">
                    {%- endif -%}
                  </div>
                  <div class="phasal-hero-card__body">
                    <div>
                      <h3 class="phasal-hero-card__title">{{ block.settings.feature_title | escape }}</h3>
                      {%- if block.settings.feature_copy != blank -%}
                        <p class="phasal-hero-card__copy">{{ block.settings.feature_copy | escape }}</p>
                      {%- endif -%}
                    </div>
                    {%- if block.settings.feature_link_label != blank -%}
                      <a class="phasal-hero-card__link" href="{{ block.settings.feature_link | default: routes.root_url }}">
                        {{ block.settings.feature_link_label | escape }}
                      </a>
                    {%- endif -%}
                  </div>
                </article>
              {%- endif -%}
            </div>
          </div>
        </article>
      {%- endfor -%}
    {%- else -%}
      {%- liquid
        assign hero_products = blank
        if section.settings.product_collection != blank
          assign hero_products = section.settings.product_collection.products
        endif
      -%}
      <article class="phasal-hero__slide is-active" data-phasal-hero-slide>
        <div class="phasal-hero__media">
          {%- if section.settings.background_image != blank -%}
            {{
              section.settings.background_image
              | image_url: width: 2400
              | image_tag:
                widths: '750, 1100, 1500, 2000, 2400',
                sizes: '100vw',
                loading: 'eager'
            }}
          {%- endif -%}
        </div>
        <div class="phasal-hero__overlay"></div>

        <div class="phasal-hero__inner">
          <div class="phasal-hero__content">
            <div class="phasal-hero__badges">
              {%- if section.settings.eyebrow != blank -%}
                <span class="phasal-hero__badge">
                  <span class="phasal-hero__badge-dot"></span>
                  {{ section.settings.eyebrow | escape }}
                </span>
              {%- endif -%}
              {%- if section.settings.meta != blank -%}
                <span class="phasal-hero__meta">{{ section.settings.meta | escape }}</span>
              {%- endif -%}
            </div>

            <h1 class="phasal-hero__title">
              {{ section.settings.heading_line_1 | escape }}<br>
              <span class="phasal-hero__title-accent">{{ section.settings.heading_line_2 | escape }}</span><br>
              <span class="phasal-hero__title-highlight">{{ section.settings.heading_line_3 | escape }}</span>
            </h1>

            {%- if section.settings.subheading != blank -%}
              <p class="phasal-hero__subtitle">{{ section.settings.subheading | escape }}</p>
            {%- endif -%}

            <div class="phasal-hero__actions">
              {%- if section.settings.primary_button_label != blank -%}
                <a class="phasal-home__button phasal-home__button--primary" href="{{ section.settings.primary_button_link | default: routes.all_products_collection_url }}">
                  {{ section.settings.primary_button_label | escape }}
                </a>
              {%- endif -%}
              {%- if section.settings.secondary_button_label != blank -%}
                <a class="phasal-home__button phasal-home__button--secondary" href="{{ section.settings.secondary_button_link | default: routes.root_url }}">
                  {{ section.settings.secondary_button_label | escape }}
                </a>
              {%- endif -%}
            </div>

            {%- if stat_blocks.size > 0 -%}
              <div class="phasal-hero__stats">
                {%- for block in stat_blocks limit: 4 -%}
                  <div {{ block.shopify_attributes }}>
                    <div class="phasal-hero__stat-number">{{ block.settings.number | escape }}</div>
                    <div class="phasal-hero__stat-label">{{ block.settings.label | escape }}</div>
                  </div>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>

          <div class="phasal-hero__cards">
            {%- if section.settings.product_collection != blank and hero_products.size > 0 -%}
              <div class="phasal-hero__card-grid">
                {%- for product in hero_products limit: 2 -%}
                  {%- assign variant = product.selected_or_first_available_variant -%}
                  <a class="phasal-hero-card phasal-hero-card--linked" href="{{ product.url }}">
                    <div class="phasal-hero-card__image">
                      {%- if product.featured_image != blank -%}
                        {{
                          product.featured_image
                          | image_url: width: 900
                          | image_tag:
                            widths: '360, 540, 720, 900',
                            sizes: '(max-width: 749px) 100vw, 28vw'
                        }}
                      {%- endif -%}
                    </div>
                    <div class="phasal-hero-card__body">
                      <h2 class="phasal-hero-card__title">{{ product.title | escape }}</h2>
                      {%- if product.metafields.custom.short_description != blank -%}
                        <p class="phasal-hero-card__copy">{{ product.metafields.custom.short_description | metafield_tag | strip_html }}</p>
                      {%- elsif product.description != blank -%}
                        <p class="phasal-hero-card__copy">{{ product.description | strip_html | truncate: 70 }}</p>
                      {%- endif -%}
                      {%- if variant != blank -%}
                        <div class="phasal-hero-card__price">
                          {{ variant.price | money }}
                          {%- if variant.unit_price_measurement != blank -%}
                            <span class="phasal-hero-card__price-unit">
                              /
                              {{ variant.unit_price_measurement.reference_value -}}
                              {{- variant.unit_price_measurement.reference_unit }}
                            </span>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    </div>
                  </a>
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- for block in feature_blocks limit: 1 -%}
              <article class="phasal-hero-card phasal-hero-card--feature" {{ block.shopify_attributes }}>
                <div class="phasal-hero-card__image">
                  {%- if block.settings.image != blank -%}
                    {{
                      block.settings.image
                      | image_url: width: 1600
                      | image_tag:
                        widths: '540, 900, 1200, 1600',
                        sizes: '(max-width: 749px) 100vw, 38vw'
                    }}
                  {%- else -%}
                    <img src="{{ 'farm_banner.png' | asset_url }}" alt="{{ block.settings.title | escape }}" width="3168" height="1344">
                  {%- endif -%}
                </div>
                <div class="phasal-hero-card__body">
                  <div>
                    <h2 class="phasal-hero-card__title">{{ block.settings.title | escape }}</h2>
                    {%- if block.settings.copy != blank -%}
                      <p class="phasal-hero-card__copy">{{ block.settings.copy | escape }}</p>
                    {%- endif -%}
                  </div>
                  {%- if block.settings.link_label != blank -%}
                    <a class="phasal-hero-card__link" href="{{ block.settings.link | default: routes.root_url }}">
                      {{ block.settings.link_label | escape }}
                    </a>
                  {%- endif -%}
                </div>
              </article>
            {%- endfor -%}
          </div>
        </div>
      </article>
    {%- endif -%}
  </div>

  {%- if hero_slide_blocks.size > 1 -%}
    <div class="phasal-hero__controls" aria-label="Hero carousel controls">
      <button type="button" class="phasal-hero__nav phasal-hero__nav--prev" data-phasal-hero-prev aria-label="Previous slide">‹</button>
      <div class="phasal-hero__dots">
        {%- for block in hero_slide_blocks -%}
          <button
            type="button"
            class="phasal-hero__dot{% if forloop.first %} is-active{% endif %}"
            data-phasal-hero-dot
            data-slide-index="{{ forloop.index0 }}"
            aria-label="Go to slide {{ forloop.index }}"
          ></button>
        {%- endfor -%}
      </div>
      <button type="button" class="phasal-hero__nav phasal-hero__nav--next" data-phasal-hero-next aria-label="Next slide">›</button>
    </div>

    <script>
      (() => {
        const carousel = document.getElementById('PhasalHero-{{ section.id }}');
        if (!carousel || carousel.dataset.heroReady === 'true') return;
        carousel.dataset.heroReady = 'true';

        const slides = Array.from(carousel.querySelectorAll('[data-phasal-hero-slide]'));
        const dots = Array.from(carousel.querySelectorAll('[data-phasal-hero-dot]'));
        const prev = carousel.querySelector('[data-phasal-hero-prev]');
        const next = carousel.querySelector('[data-phasal-hero-next]');
        const shouldAutoRotate = carousel.dataset.autoRotate === 'true';
        const interval = Number(carousel.dataset.interval || 5000);
        let currentIndex = 0;
        let timerId = null;

        const showSlide = (index) => {
          currentIndex = (index + slides.length) % slides.length;
          slides.forEach((slide, slideIndex) => {
            slide.classList.toggle('is-active', slideIndex === currentIndex);
          });
          dots.forEach((dot, dotIndex) => {
            dot.classList.toggle('is-active', dotIndex === currentIndex);
          });
        };

        const startAutoRotate = () => {
          if (!shouldAutoRotate || slides.length < 2) return;
          window.clearInterval(timerId);
          timerId = window.setInterval(() => {
            showSlide(currentIndex + 1);
          }, interval);
        };

        prev?.addEventListener('click', () => {
          showSlide(currentIndex - 1);
          startAutoRotate();
        });

        next?.addEventListener('click', () => {
          showSlide(currentIndex + 1);
          startAutoRotate();
        });

        dots.forEach((dot) => {
          dot.addEventListener('click', () => {
            showSlide(Number(dot.dataset.slideIndex));
            startAutoRotate();
          });
        });

        carousel.addEventListener('mouseenter', () => window.clearInterval(timerId));
        carousel.addEventListener('mouseleave', startAutoRotate);

        showSlide(0);
        startAutoRotate();
      })();
    </script>
  {%- endif -%}
</section>

