{{ 'phasal-shell.css' | asset_url | stylesheet_tag }}

<footer class="phasal-shell phasal-footer">
  <div class="phasal-shell__inner phasal-footer__main">
    <div class="phasal-footer__brand">
      {%- if settings.logo != blank -%}
        {{
          settings.logo
          | image_url: width: 500
          | image_tag:
            widths: '120, 180, 240, 320, 500',
            sizes: '160px',
            alt: settings.logo.alt | default: shop.name
        }}
      {%- else -%}
        <div class="phasal-header__brand-name">{{ shop.name }}</div>
      {%- endif -%}

      <p class="phasal-footer__brand-copy">{{ section.settings.about_text }}</p>

      {%- if section.settings.show_social -%}
        <div class="phasal-footer__social">
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" aria-label="Instagram">
              <svg class="phasal-social-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_facebook_link != blank -%}
            <a href="{{ settings.social_facebook_link }}" aria-label="Facebook">
              <svg class="phasal-social-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_youtube_link != blank -%}
            <a href="{{ settings.social_youtube_link }}" aria-label="YouTube">
              <svg class="phasal-social-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_linkedin_link != blank -%}
            <a href="{{ settings.social_linkedin_link }}" aria-label="LinkedIn">
              <svg class="phasal-social-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div>
      <h2 class="phasal-footer__heading">{{ section.settings.menu_heading_1 }}</h2>
      <div class="phasal-footer__menu">
        {%- for link in section.settings.footer_menu_1.links -%}
          <a href="{{ link.url }}">{{ link.title | escape }}</a>
        {%- endfor -%}
      </div>
    </div>

    <div>
      <h2 class="phasal-footer__heading">{{ section.settings.menu_heading_2 }}</h2>
      <div class="phasal-footer__menu">
        {%- for link in section.settings.footer_menu_2.links -%}
          <a href="{{ link.url }}">{{ link.title | escape }}</a>
        {%- endfor -%}
      </div>
    </div>

    {%- if section.settings.footer_menu_3 != blank -%}
      <div>
        <h2 class="phasal-footer__heading">{{ section.settings.menu_heading_3 }}</h2>
        <div class="phasal-footer__menu">
          {%- for link in section.settings.footer_menu_3.links -%}
            <a href="{{ link.url }}">{{ link.title | escape }}</a>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <div class="phasal-footer__contact">
      <h2 class="phasal-footer__heading">{{ section.settings.contact_heading }}</h2>
      <p>{{ section.settings.contact_address }}</p>
      <p><a href="tel:{{ section.settings.contact_phone | replace: ' ', '' }}">{{ section.settings.contact_phone }}</a></p>
      <p><a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a></p>

      {%- if section.settings.newsletter_enable -%}
        <div class="phasal-footer__newsletter">
          <h2 class="phasal-footer__heading">{{ section.settings.newsletter_heading }}</h2>
          {%- form 'customer', class: 'phasal-footer__newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input type="email" name="contact[email]" placeholder="Enter your email" required>
            <button type="submit">Subscribe</button>
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  <div class="phasal-shell__inner phasal-footer__bottom">
    <div>
      © {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
    </div>
    <div class="phasal-footer__payments">
      {%- if section.settings.payment_enable and shop.enabled_payment_types != empty -%}
        {%- for type in shop.enabled_payment_types limit: 6 -%}
          <span class="phasal-footer__payment">{{ type | replace: '_', ' ' | capitalize }}</span>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "about_text",
      "label": "About text",
      "default": "Organic millets, cold-pressed oils, and direct-from-farmer staples shaped for healthier kitchens."
    },
    {
      "type": "text",
      "id": "menu_heading_1",
      "label": "Menu heading 1",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "footer_menu_1",
      "label": "Footer menu 1"
    },
    {
      "type": "text",
      "id": "menu_heading_2",
      "label": "Menu heading 2",
      "default": "Company"
    },
    {
      "type": "link_list",
      "id": "footer_menu_2",
      "label": "Footer menu 2"
    },
    {
      "type": "text",
      "id": "menu_heading_3",
      "label": "Menu heading 3",
      "default": "Resources"
    },
    {
      "type": "link_list",
      "id": "footer_menu_3",
      "label": "Footer menu 3"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact heading",
      "default": "Contact"
    },
    {
      "type": "textarea",
      "id": "contact_address",
      "label": "Address",
      "default": "Raigarh, Chhattisgarh, India"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Phone",
      "default": "+91 00000 00000"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email",
      "default": "hello@example.com"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "label": "Show newsletter",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Subscribe for updates"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social links",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "label": "Show payment types",
      "default": true
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
