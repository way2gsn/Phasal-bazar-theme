{{ 'phasal-shell.css' | asset_url | stylesheet_tag }}

<footer class="phasal-shell phasal-footer">
  <div class="phasal-shell__inner phasal-footer__main">
    <div class="phasal-footer__brand">
      {%- if settings.logo != blank -%}
        {{
          settings.logo
          | image_url: width: 500
          | image_tag:
            widths: '120, 180, 240, 320, 500',
            sizes: '160px',
            alt: settings.logo.alt | default: shop.name
        }}
      {%- else -%}
        <div class="phasal-header__brand-name">{{ shop.name }}</div>
      {%- endif -%}

      <p class="phasal-footer__brand-copy">{{ section.settings.about_text }}</p>

      {%- if section.settings.show_social -%}
        <div class="phasal-footer__social">
          {%- if settings.social_instagram_link != blank -%}<a href="{{ settings.social_instagram_link }}" aria-label="Instagram">IG</a>{%- endif -%}
          {%- if settings.social_facebook_link != blank -%}<a href="{{ settings.social_facebook_link }}" aria-label="Facebook">FB</a>{%- endif -%}
          {%- if settings.social_youtube_link != blank -%}<a href="{{ settings.social_youtube_link }}" aria-label="YouTube">YT</a>{%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div>
      <h2 class="phasal-footer__heading">{{ section.settings.menu_heading_1 }}</h2>
      <div class="phasal-footer__menu">
        {%- for link in section.settings.footer_menu_1.links -%}
          <a href="{{ link.url }}">{{ link.title | escape }}</a>
        {%- endfor -%}
      </div>
    </div>

    <div>
      <h2 class="phasal-footer__heading">{{ section.settings.menu_heading_2 }}</h2>
      <div class="phasal-footer__menu">
        {%- for link in section.settings.footer_menu_2.links -%}
          <a href="{{ link.url }}">{{ link.title | escape }}</a>
        {%- endfor -%}
      </div>
    </div>

    <div class="phasal-footer__contact">
      <h2 class="phasal-footer__heading">{{ section.settings.contact_heading }}</h2>
      <p>{{ section.settings.contact_address }}</p>
      <p><a href="tel:{{ section.settings.contact_phone | replace: ' ', '' }}">{{ section.settings.contact_phone }}</a></p>
      <p><a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a></p>

      {%- if section.settings.newsletter_enable -%}
        <div class="phasal-footer__newsletter">
          <h2 class="phasal-footer__heading">{{ section.settings.newsletter_heading }}</h2>
          {%- form 'customer', class: 'phasal-footer__newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input type="email" name="contact[email]" placeholder="Enter your email" required>
            <button type="submit">Subscribe</button>
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  <div class="phasal-shell__inner phasal-footer__bottom">
    <div>
      © {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
    </div>
    <div class="phasal-footer__payments">
      {%- if section.settings.payment_enable and shop.enabled_payment_types != empty -%}
        {%- for type in shop.enabled_payment_types limit: 6 -%}
          <span class="phasal-footer__payment">{{ type | replace: '_', ' ' | capitalize }}</span>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "about_text",
      "label": "About text",
      "default": "Organic millets, cold-pressed oils, and direct-from-farmer staples shaped for healthier kitchens."
    },
    {
      "type": "text",
      "id": "menu_heading_1",
      "label": "Menu heading 1",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "footer_menu_1",
      "label": "Footer menu 1"
    },
    {
      "type": "text",
      "id": "menu_heading_2",
      "label": "Menu heading 2",
      "default": "Company"
    },
    {
      "type": "link_list",
      "id": "footer_menu_2",
      "label": "Footer menu 2"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact heading",
      "default": "Contact"
    },
    {
      "type": "textarea",
      "id": "contact_address",
      "label": "Address",
      "default": "Raigarh, Chhattisgarh, India"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Phone",
      "default": "+91 00000 00000"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email",
      "default": "hello@example.com"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "label": "Show newsletter",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Subscribe for updates"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social links",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "label": "Show payment types",
      "default": true
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
