{{ 'phasal-shell.css' | asset_url | stylesheet_tag }}

<section class="phasal-shell phasal-announcement">
  <div class="phasal-announcement__track">
    {%- for repeat in (1..2) -%}
      {%- for block in section.blocks -%}
        <div class="phasal-announcement__item" {{ block.shopify_attributes }}>
          {{ block.settings.text | escape }}
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Announcement Bar",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Stone-Ground and Unpolished"
        }
      ]
    }
  ],
  "settings": [],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        { "type": "announcement", "settings": { "text": "Stone-Ground and Unpolished" } },
        { "type": "announcement", "settings": { "text": "Cold-Pressed Oils - No Heat, No Chemicals" } },
        { "type": "announcement", "settings": { "text": "Free Delivery on Orders Above Rs. 499" } },
        { "type": "announcement", "settings": { "text": "Sourced Direct - Dongitara Millet Processing Unit, Raigarh" } }
      ]
    }
  ]
}
{% endschema %}
