{{ 'phasal-home.css' | asset_url | stylesheet_tag }}

<section class="phasal-about-stats section-{{ section.id }}">
  <div class="phasal-about-stats__media">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2800 | image_tag: loading: 'lazy' }}
    {%- endif -%}
  </div>
  <div class="phasal-about-stats__overlay"></div>
  <div class="phasal-home__inner">
    <div class="phasal-about-stats__grid">
      {%- for block in section.blocks -%}
        <div class="phasal-about-stats__item" {{ block.shopify_attributes }}>
          <div class="phasal-about-stats__number">{{ block.settings.number | escape }}</div>
          <div class="phasal-about-stats__label">{{ block.settings.label | escape }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.phasal-about-stats {
  position: relative;
  padding: 10rem 0;
  overflow: hidden;
  background: #1b3022;
}

.phasal-about-stats__media {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.phasal-about-stats__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.25;
}

.phasal-about-stats__overlay {
  position: absolute;
  inset: 0;
  z-index: 2;
  background: rgba(27, 48, 34, 0.4);
}

.phasal-about-stats__grid {
  position: relative;
  z-index: 3;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 4rem;
  text-align: center;
}

.phasal-about-stats__number {
  color: #fff;
  font-family: 'Playfair Display', serif;
  font-size: clamp(6.4rem, 10vw, 8.8rem);
  line-height: 1;
  margin-bottom: 0.8rem;
  letter-spacing: -0.01em;
}

.phasal-about-stats__label {
  color: #ddb296;
  font-size: 1.3rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  max-width: 14rem;
  margin: 0 auto;
}

@media screen and (max-width: 749px) {
  .phasal-about-stats__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 4.8rem 2.4rem;
  }
}
</style>

{% schema %}
{
  "name": "Phasal About Stats",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background Image" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "72K" },
        { "type": "text", "id": "label", "label": "Label", "default": "Lives Transformed" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Phasal About Stats",
      "blocks": [
        { "type": "stat", "settings": { "number": "72K", "label": "Lives Transformed" } },
        { "type": "stat", "settings": { "number": "12M", "label": "Acres Protected" } },
        { "type": "stat", "settings": { "number": "100%", "label": "Fair Profit" } },
        { "type": "stat", "settings": { "number": "0", "label": "Synthetic Chemicals" } }
      ]
    }
  ]
}
{% endschema %}
